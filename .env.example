# ==============================================================
# .env.example — Copy ke .env dan isi nilainya
# ==============================================================

APP_NAME="Zain Hanger"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
ADMIN_URL=http://localhost:8000/admin

# Database MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zain_hanger
DB_USERNAME=root
DB_PASSWORD=

# Google OAuth — Daftar di console.cloud.google.com
# Authorized redirect URIs: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/auth/google/callback"

# Pusher — Realtime notifikasi (bisa pakai Laravel Reverb gratis)
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=ap1

# Atau pakai Laravel Reverb (self-hosted, gratis):
# BROADCAST_CONNECTION=reverb
# REVERB_APP_ID=my-app
# REVERB_APP_KEY=my-key
# REVERB_APP_SECRET=my-secret
# REVERB_HOST="localhost"
# REVERB_PORT=8080
# REVERB_SCHEME=http

# Cache & Session
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database

# Mail (untuk password reset dll)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@zainhanger.com"
MAIL_FROM_NAME="${APP_NAME}"

# Storage
FILESYSTEM_DISK=public
